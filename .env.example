# ============================================================
#  H2BApply v15.0 — Variáveis de Ambiente (SERVIDOR DE TESTE)
#  Copie este arquivo para .env e preencha os valores
#  NÃO suba o .env para o GitHub — apenas o .env.example
# ============================================================

# URL pública do servidor de TESTE (sem barra no final)
# Ex: https://h2bapply-teste.onrender.com
APP_URL=https://h2b-teste.onrender.com

# Google OAuth 2.0 — use credenciais do projeto de TESTE
# (crie um projeto separado no Google Cloud Console para não afetar produção)
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=seu_client_id_de_teste.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu_client_secret_de_teste

# E-mail do administrador principal (terá acesso ao painel /admin)
ADMIN_EMAIL=seu@gmail.com

# E-mail do administrador secundário (opcional — deixe vazio se não precisar)
ADMIN_EMAIL_2=

# Web Push Notifications (opcional)
# Gere suas chaves com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@gmail.com

# Diretório de dados persistentes
# No Render: configure um Disk com Mount Path = /data
# Localmente: deixe vazio (usa /tmp automaticamente)
DATA_DIR=/data

# Porta do servidor (Render define automaticamente)
PORT=3000

# Token de acesso aos logs de debug
# Acesse: https://h2bapply-teste.onrender.com/logs?token=SEU_TOKEN
LOG_ACCESS_TOKEN=h2blogs2026
