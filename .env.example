# ============================================================
#  H2BApply v15.0 — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  NÃO suba o .env para o GitHub — apenas o .env.example
# ============================================================

# URL pública do seu site (sem barra no final)
# Exemplo Render: https://h2bapply.onrender.com
# Exemplo local:  http://localhost:3000
APP_URL=http://localhost:3000

# ── MULTI-SERVIDOR ──────────────────────────────────────────
# Identidade deste deploy no sistema de servidores.
#   Produção (h2bapply.com)........... SERVER_ID=1
#   Servidor 2 (h2b-teste.onrender.com) SERVER_ID=2
# O MESMO código roda nos dois — só esta variável muda.
# Se não definir, assume 1.
SERVER_ID=1

# Google OAuth 2.0
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-seu_client_secret

# E-mail do administrador principal (terá acesso ao painel /admin)
ADMIN_EMAIL=seu@gmail.com

# E-mail do administrador secundário (opcional — deixe vazio se não precisar)
# NÃO coloque e-mails diretamente no código-fonte
ADMIN_EMAIL_2=

# Web Push Notifications (opcional)
# Gere suas chaves com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu@gmail.com

# Diretório de dados persistentes
# No Render: configure um Disk com Mount Path = /data
# Localmente: deixe vazio (usa /tmp automaticamente)
DATA_DIR=/data

# Porta do servidor (Render define automaticamente)
PORT=3000

# ── IA (Gemini) ─────────────────────────────────────────────
# Chave da API do Google Gemini (aprovação de comprovantes, chat, auditorias)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Limite global de mensagens/dia para todos os usuários (padrão 1500)
GEMINI_DAILY_LIMIT=1500

# ── Segurança ───────────────────────────────────────────────
# Chave de cifragem dos tokens Gmail no disco (QUALQUER string forte).
# Sem ela os tokens ficam em TEXTO PURO — defina em produção!
DATA_ENC_KEY=

# Senhas dos editores no painel admin (não deixe as padrão em produção)
EDITOR_PWD_ANDREW=
EDITOR_PWD_DIEGO=

# ── Storage engine (opcional — padrões já são os corretos) ──
# STORAGE=json força o modo JSON antigo (desativa SQLite)
STORAGE=
# STORAGE_MIRROR=off desliga o espelho JSON (só após semanas estável!)
STORAGE_MIRROR=

# ── Memória (servidores com 512 MB de RAM — ex.: Render Starter) ──
# Evita o 502 em loop "Ran out of memory (used over 512MB)": obriga o
# Node a fazer faxina de memória antes de estourar o limite do plano.
# Em servidor com 1 GB+ pode deixar vazio.
NODE_OPTIONS=--max-old-space-size=360

# ── Reset de temporada (NUNCA deixe definida permanentemente) ──
# Defina RESET_NOW=<token qualquer> e faça deploy para zerar a temporada
# UMA vez; depois remova a variável.
RESET_NOW=
